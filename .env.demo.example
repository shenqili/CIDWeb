# CIDWeb demo environment

APP_ENV=demo
TZ=Asia/Shanghai

POSTGRES_DB=cidweb
POSTGRES_USER=cidweb
POSTGRES_PASSWORD=cidweb
DATABASE_URL=postgresql://cidweb:cidweb@postgres:5432/cidweb

REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me-in-demo

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

FILE_STORAGE_ROOT=/storage
RAW_STORAGE_ROOT=/storage/raw
INTERMEDIATE_STORAGE_ROOT=/storage/intermediate
EXPORT_STORAGE_ROOT=/storage/exports
CHART_STORAGE_ROOT=/storage/charts
MANIFEST_STORAGE_ROOT=/storage/manifests
AUDIT_ATTACHMENT_STORAGE_ROOT=/storage/audit-attachments

